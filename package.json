{
	"name": "crosswalker",
	"version": "0.1.0",
	"description": "Import structured ontologies into Obsidian with hierarchical folder structures, typed links, and metadata.",
	"main": "main.js",
	"scripts": {
		"dev": "bun run esbuild.config.mjs",
		"build": "bun x tsc -noEmit -skipLibCheck && bun run esbuild.config.mjs production",
		"version": "bun run version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"e2e": "wdio run wdio.conf.mts"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"frameworks",
		"ontology",
		"taxonomy",
		"compliance",
		"GRC",
		"crosswalk",
		"import"
	],
	"author": "cybersader",
	"license": "MIT",
	"devDependencies": {
		"@eslint/json": "^0.14.0",
		"@types/jest": "^29.5.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^20.10.0",
		"@types/papaparse": "^5.3.14",
		"@typescript-eslint/parser": "^8.48.1",
		"@typescript-eslint/utils": "^8.48.1",
		"@wdio/cli": "^9.27.0",
		"@wdio/local-runner": "^9.27.0",
		"@wdio/mocha-framework": "^9.27.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "0.19.0",
		"eslint": "^9.39.1",
		"eslint-plugin-obsidianmd": "^0.1.9",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^29.7.0",
		"obsidian": "latest",
		"ts-jest": "^29.1.0",
		"tslib": "2.6.0",
		"typescript": "5.2.2",
		"typescript-eslint": "^8.48.1",
		"wdio-obsidian-reporter": "^3.0.2",
		"wdio-obsidian-service": "^3.0.2"
	},
	"dependencies": {
		"papaparse": "^5.4.1",
		"xlsx": "^0.18.5"
	}
}
